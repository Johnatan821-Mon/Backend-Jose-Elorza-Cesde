# ===================================================================
# VARIABLES DE PRODUCCIÓN — VPS
#
# 1. Copiar este archivo como .env en la raíz del proyecto en el servidor:
#       cp .env.prod.example .env
# 2. Completar TODOS los valores marcados con CAMBIAR_POR_...
# 3. Restringir permisos (solo el propietario puede leerlo):
#       chmod 600 .env
#
# NUNCA subas .env a git — ya está en .gitignore
# ===================================================================

# ── Spring ───────────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod

# ── Base de datos ────────────────────────────────────────────────────────────
# DB_URL NO es necesario aquí: docker-compose.prod.yml lo sobreescribe
# automáticamente para usar el servicio "postgres" interno del compose.
DB_NAME=clientesdb
DB_USERNAME=clientes_user
DB_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURO_MIN_20_CHARS

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generar con: openssl rand -hex 32
JWT_SECRET=CAMBIAR_POR_SECRETO_HEX_64_CHARS
JWT_EXPIRATION=86400000

# ── Google Calendar (opcional) ───────────────────────────────────────────────
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_CREDENTIALS_FILE=credentials.json
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=America/Bogota
