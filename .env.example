# ===================================================================
# VARIABLES DE ENTORNO — Copia este archivo como .env y completa los valores
# NUNCA subas .env a git (ya está en .gitignore)
# ===================================================================

# Perfil de Spring
SPRING_PROFILES_ACTIVE=prod

# Base de datos PostgreSQL
# ↓ Local con Docker Compose:
#   DB_URL=jdbc:postgresql://localhost:5432/clientesdb
# ↓ Producción en VPS con docker-compose.prod.yml (usa el service name "postgres"):
#   DB_URL se sobreescribe automáticamente en docker-compose.prod.yml
DB_URL=jdbc:postgresql://localhost:5432/clientesdb
DB_USERNAME=clientes_user
DB_PASSWORD=clientes_pass
DB_NAME=clientesdb

# JWT — genera un valor seguro con: openssl rand -hex 32
JWT_SECRET=reemplaza-con-secreto-seguro-de-minimo-32-caracteres
JWT_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=604800000

# Google Calendar (dejar en false si no se usa)
GOOGLE_CALENDAR_ENABLED=false
GOOGLE_CALENDAR_CREDENTIALS_FILE=credentials.json
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=America/Bogota

# pgAdmin (solo para docker-compose.yml local, no usar en prod)
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=admin
